# Model Swapping Configuration
# Copy to .env and edit to swap models or tune parameters.
# Changes take effect on: docker compose up (or docker compose restart text2sql nlg)

# --- Text-to-SQL model (code generation) ---
TEXT2SQL_MODEL=/models/qwen2.5-coder-1.5b-instruct-q4_k_m.gguf
TEXT2SQL_CTX_SIZE=2048
TEXT2SQL_EXTRA_FLAGS=

# --- NLG model (natural language answer generation) ---
NLG_MODEL=/models/Qwen3.5-2B-Q4_K_M.gguf
NLG_CTX_SIZE=2048
NLG_EXTRA_FLAGS=--reasoning-budget 0
